APP_NAME=go_app
ENVIRONMENT=local #local|development|production
PORT=8080
DEBUG=true

DATABASE_SQL__HOST=127.0.0.1
DATABASE_SQL__DATABASE=postgres
DATABASE_SQL__USERNAME=username
DATABASE_SQL__PASSWORD=password

# DATABASE_REDIS__ADDR=127.0.0.1:6379
# DATABASE_REDIS__PASSWORD=
# DATABASE_REDIS__DB=0

OTEL_ENABLE=true

HTTP_JSON_NAMING=snake_case

# S3/MinIO (Railway)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_USE_SSL=true
# Optional public base URL, defaults to https://S3_ENDPOINT when SSL=true
S3_PUBLIC_BASE_URL=

# Optional base URL used to generate branded public links (e.g. https://pichost.io)
APP_PUBLIC_BASE_URL=

KAFKA_BROKERS=127.0.0.1:9092
KAFKA_CA_CERT_PATH=storage/cert/ca.crt
KAFKA_KEY_PATH=storage/cert/ca.crt
KAFKA_CERT_PATH_PATH=storage/cert/ca.crt

# Google OAuth 2.0
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/api/v1/public/auth/google/callback
AUTH_GOOGLE_CLIENT_I_D=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_REDIRECT_U_R_L=http://localhost:8080/api/v1/public/auth/google/callback

# Frontend URL (for redirecting after Google OAuth callback)
AUTH_FRONTEND_U_R_L=http://localhost:3000

# Set to false for local dev (HTTP). Set true only on HTTPS production.
AUTH_REFRESH_COOKIE_SECURE=false
